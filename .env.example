# =================================
# ClearMyChallan — Frontend Env
# =================================
# Copy to `.env` (or `.env.local`) and fill in. All Vite env vars
# accessible in the browser MUST be prefixed with VITE_.

# Where the API server is reachable from the browser.
# Local dev:    http://localhost:4000/api
# Production:   https://api.clearmychallan.in/api
VITE_API_BASE_URL=http://localhost:4000/api

# Optional: Razorpay public key (also exposed via /api/payments/config).
# Setting it here lets the frontend pre-load Razorpay before the
# user clicks Pay. Safe to ship — it's the *publishable* key.
VITE_RAZORPAY_KEY_ID=

# Brand + contact
VITE_BRAND_NAME=ClearMyChallan
VITE_SUPPORT_PHONE=8000727771
VITE_WHATSAPP_NUMBER=918000727771
