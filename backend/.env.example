# =============================================
# ClearMyChallan — Backend Environment Template
# =============================================
# Copy this file to `.env` and fill in real values.
# NEVER commit your real `.env` file to source control.

# ---- Server ----
NODE_ENV=development
PORT=4000
# Comma-separated list of frontend origins allowed by CORS.
FRONTEND_URL=http://localhost:5173

# ---- MongoDB ----
# Local:    mongodb://127.0.0.1:27017/challan_resolve
# Atlas:    mongodb+srv://<user>:<pass>@<cluster>/challan_resolve
MONGO_URI=mongodb+srv://shubhammittal3555_db_user:<NRss@78800306>@challan.za54oi7.mongodb.net/?appName=CHALLAN

PORT=4000
# ---- JWT ----
# Use a long random string in production (openssl rand -hex 64).
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- Challan Provider API ----
# Plug in any Indian e-Challan / Parivahan aggregator (Surepass, Signzy, Gridlines, etc.)
# When these are blank, the backend falls back to mock data so the UI keeps working.
CHALLAN_API_URL=
CHALLAN_API_KEY=
CHALLAN_API_PROVIDER=mock

# ---- UPI Direct QR Payment (primary, no gateway needed) ----
# Your UPI VPA / handle. e.g. "shubham@paytm", "9876543210@upi", "merchant@hdfcbank"
# When blank, the track page shows a "WhatsApp us" fallback instead of QR.
UPI_ID=
# Name shown to customer in their UPI app (max 25 chars).
UPI_PAYEE_NAME=ClearMyChallan

# ---- Razorpay (OPTIONAL — kept as backup gateway path) ----
# Only needed if you later want gateway-based payment instead of UPI QR.
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Cloudinary (Document upload storage) ----
# Get from https://cloudinary.com/console
# Blank → uploads disabled (server returns 503 on /api/cases/submit).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=clearmychallan/cases

# ---- File upload limits ----
MAX_UPLOAD_BYTES=20971520
ALLOWED_UPLOAD_MIMES=image/jpeg,image/png,image/jpg,application/pdf

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ---- Bootstrap admin (optional) ----
# When set, `npm run seed` will create this admin account.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin
